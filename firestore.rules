rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: key
    // Fields:
    //   - key: string (required)
    //   - value: string (required)
    //
    // Collection: registrations
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - class: string (required)
    //   - school: string (required)
    //   - mobile: string (required)
    //   - created_at: string (required)
    //
    // Collection: notifications
    // Document ID: auto-generated
    // Fields:
    //   - message: string (required)
    //   - created_at: string (required)
    //
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - image_url: string (required)
    //   - type: string (required)
    //   - created_at: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'vrishketuray0@gmail.com';
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidSetting(data) {
      return data.key is string && data.value is string;
    }

    function isValidRegistration(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.class is string && data.class.size() > 0 && data.class.size() < 50 &&
             data.school is string && data.school.size() > 0 && data.school.size() < 100 &&
             data.mobile is string && data.mobile.size() > 0 && data.mobile.size() < 20 &&
             data.created_at is string;
    }

    function isValidNotification(data) {
      return data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.created_at is string;
    }

    function isValidPost(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 2000 &&
             data.image_url is string && data.image_url.size() < 1000 &&
             data.type is string && data.type.size() < 50 &&
             data.created_at is string;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && hasRequiredFields(['key', 'value']) && isValidSetting(request.resource.data);
      allow delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow read: if isAdmin();
      allow create: if hasRequiredFields(['name', 'class', 'school', 'mobile', 'created_at']) && isValidRegistration(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create, update: if isAdmin() && hasRequiredFields(['message', 'created_at']) && isValidNotification(request.resource.data);
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create, update: if isAdmin() && hasRequiredFields(['title', 'description', 'image_url', 'type', 'created_at']) && isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
