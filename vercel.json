{
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.ugrasenaedu.in/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
